# Environment Variables Template
# Copy this to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/brand_strategy_db"

# Backend
BACKEND_PORT=3001
NODE_ENV=development
PORTAL_INTAKE_EVENT_STORE_MODE=dual
# Optional: throttle for DB fallback warning events (milliseconds)
PORTAL_INTAKE_DB_FALLBACK_WARNING_MS=60000
PORTAL_EMAIL_VERIFY_CODE=00000
PORTAL_SIGNUP_SCAN_MODE=deep
PORTAL_SIGNUP_DDG_ENABLED=true
PORTAL_LIBRARY_V2_ENABLED=true
PORTAL_LIBRARY_TRUST_GUARD_ENABLED=true
PORTAL_LIBRARY_HIDE_IDS_ENABLED=true
PORTAL_LIBRARY_HARD_CLEANUP_ENABLED=false
PORTAL_CHAT_IMAGE_UPLOADS_V1=true
PORTAL_CHAT_UPLOAD_CAPABILITIES_V1=true
PORTAL_CHAT_UPLOAD_STRICT_ERRORS_V1=true
NEXT_PUBLIC_PORTAL_SIGNUP_SMART_SCROLL_V1=true

# Runtime resilience defaults (override only if needed)
CHAT_TOOL_TIMEOUT_MS=45000
CHAT_TOTAL_TOOL_TIMEOUT_MS=180000
CHAT_MAX_TOOL_LOOP_ITERATIONS=6
CHAT_TOOL_MAX_RETRIES=2

# OpenAI API
OPENAI_API_KEY="OPENAI_API_KEY_FROM_SECRET_MANAGER"
