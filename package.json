{
    "name": "brand-strategy-manager",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace=apps/frontend & npm run dev --workspace=apps/backend",
        "dev:frontend": "npm run dev --workspace=apps/frontend",
        "dev:client-portal": "npm run dev --workspace=apps/client-portal",
        "dev:backend": "npm run dev --workspace=apps/backend",
        "build": "if [ \"$VERCEL\" = \"1\" ]; then npm run build:vercel; else npm run build --workspaces; fi",
        "build:vercel": "npm run build --workspace=apps/frontend",
        "lint": "npm run lint --workspaces",
        "quality:file-lines": "node scripts/quality/check-file-lines.cjs",
        "security:scan-main": "node scripts/security/scan-main-hardening.cjs"
    },
    "devDependencies": {
        "typescript": "^5.3.0"
    }
}
